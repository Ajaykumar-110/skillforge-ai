# Real API Keys for SkillForge AI
# Copy this file to .env and add your actual API keys

# Adzuna Job Search API
VITE_ADZUNA_APP_ID=your_adzuna_app_id
VITE_ADZUNA_API_KEY=your_adzuna_api_key

# Udemy API
VITE_UDEMY_CLIENT_ID=your_udemy_client_id
VITE_UDEMY_CLIENT_SECRET=your_udemy_client_secret

# GitHub API (no key needed for public repos)
# GitHub API is used without authentication for public repositories

# Notes:
# 1. Get Adzuna API keys from: https://developer.adzuna.com/overview
# 2. Get Udemy API keys from: https://www.udemy.com/developers/affiliate/
# 3. GitHub API works without keys for public repositories
# 4. All environment variables must start with VITE_ for Vite projects

# Optional: point the frontend to an external backend (e.g., Flask on Railway/Render)
# Example: VITE_API_BASE_URL=https://your-backend.example.com
VITE_API_BASE_URL=http://127.0.0.1:5000

# Postgres (for Vercel serverless API routes)
# Recommended: Neon via Vercel integration (creates env vars automatically on Vercel)
# POSTGRES_URL=postgres://...
