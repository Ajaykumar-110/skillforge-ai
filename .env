# Default environment variables for SkillForge AI
# Replace with your actual API keys for# Simple Configuration - Easy to modify
VITE_API_BASE_URL=http://127.0.0.1:5000
VITE_APP_TITLE=SkillForge AI
VITE_APP_VERSION=1.0.0

# Adzuna Job Search API (optional - will fallback to LinkedIn if not set)
VITE_ADZUNA_APP_ID=demo_app_id
VITE_ADZUNA_API_KEY=demo_api_key

# Udemy API (optional - will fallback to Udemy search if not set)
VITE_UDEMY_CLIENT_ID=demo_client_id
VITE_UDEMY_CLIENT_SECRET=demo_client_secret
